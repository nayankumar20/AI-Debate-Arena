# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ai-debate-arena?retryWrites=true&w=majority

# JWT secret — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# CORS — Vite default dev port
FRONTEND_URL=http://localhost:5173

# OpenRouter (https://openrouter.ai/) — chat completions for live debates + AI Judge
OPENROUTER_API_KEY=
OPENROUTER_JUDGE_MODEL=openai/gpt-4o-mini
# Optional: OpenRouter asks for an HTTP referer on some accounts
OPENROUTER_HTTP_REFERER=http://localhost:5173
